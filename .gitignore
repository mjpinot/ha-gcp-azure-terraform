# --- Terraform ---
# Local state files and state backups (DO NOT commit these)
*.tfstate
*.tfstate.*
*.tfstate.lock.info

# Crash log files
crash.log

# Exclude all .tfvars files as they contain sensitive secrets
*.tfvars
*.tfvars.json

# Downloaded provider binaries and external modules
.terraform/
.terraformrc
terraform.rc

# Override files
override.tf
override.tf.json
*_override.tfvars
*_override.tf
*_override.tf.json


